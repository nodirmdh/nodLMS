datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl"]
}

model Branch {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  address      String
  courses      Course[]
  fines        Fine[]
  bonuses      Bonus[]
  transactions Transaction[]
  users        UserBranch[]
  Lesson       Lesson[]
}

model Leed {
  id              Int             @id @default(autoincrement())
  fio             String
  phone           String
  discoveryMethod DiscoveryMethod
  status          LeedStatus      @default(new)
  comment         String
  startTime       String
  endTime         String
  classDays       ClassDays[]     @default([every])
  courseId        Int?
  course          Course?         @relation(fields: [courseId], references: [id])
  authorId        Int?
  author          User?           @relation(fields: [authorId], references: [id])
  date            DateTime?
  /// Порядок карточки внутри колонки Kanban. Меньше = выше.
  position        Int             @default(0)
  /// Свободный текст, почему лид отказался (заполняется при status = refused).
  refusedReason   String?

  @@index([status, authorId])
  @@index([date])
  @@index([status, position])
}

model User {
  id                 Int               @id @default(autoincrement())
  fio                String
  phone              String            @unique
  phoneSecond        String?
  documentSeries     String?
  status             UserStatusType?   @default(work)
  documentNo         String?
  salaryMentorType   MentorSalaryType?
  salaryMentor       Int?
  branches           UserBranch[]
  salary             Int?              @default(0)
  telegram           String?
  sex                String?
  birthday           String?
  socialStatus       String?
  education          String?
  familyStatus       String?
  address            String?
  cardNo             String?
  cardPlaceholder    String?
  lang               String?           @default("ru")
  branch             Int?              @default(1)
  balance            Float?            @default(0)
  availableBalance   Float?            @default(0)
  acceptedBalance    Float?            @default(0)
  role               Role[]
  groups             Group[]           @relation("ResponsibleGroups")
  leeds              Leed[]
  mentor             Mentor?
  responsibleLessons Lesson[]          @relation("ResponsibleForLessons")
  authorTransactions Transaction[]     @relation("AuthorTransactions")
  transactions       Transaction[]     @relation("UserTransactions")
  finesReceived      Fine[]            @relation("FinesReceived")
  finesAuthored      Fine[]            @relation("FinesAuthored")
  bonusesReceived    Bonus[]           @relation("BonusesReceived")
  bonusesAuthored    Bonus[]           @relation("BonusesAuthored")
  avatar             String?
  responsibleExams   Exam[]            @relation("ResponsibleExams")
  studentBonus       StudentBonus[]

  @@map("users")
}

model Avatar {
  id  Int    @id @default(autoincrement())
  url String
}

model UserBranch {
  userId   Int
  branchId Int
  user     User   @relation(fields: [userId], references: [id])
  branch   Branch @relation(fields: [branchId], references: [id])

  @@id([userId, branchId])
}

model Mentor {
  id      Int           @id @default(autoincrement())
  userId  Int           @unique
  user    User          @relation(fields: [userId], references: [id])
  status  MentorStatus? @default(active)
  lessons Lesson[]
  courses Course[]
  groups  Group[]       @relation("MentorGroup")

  @@map("mentors")
}

model Student {
  id             Int               @id @default(autoincrement())
  fio            String
  balance        Float?            @default(0)
  phone          String
  sex            String?
  telegram       String?
  documentSeries String?
  documentNo     String?
  birthday       String
  pinfl          String?
  status         StudentStatus?    @default(active)
  lessons        StudentOnLesson[]
  courses        Course[]
  groupStudents  GroupStudent[]
  fatherFio      String?
  fatherPhone    String?
  fatherJob      String?
  montherFio     String?
  montherPhone   String?
  montherJob     String?
  disability     Boolean?          @default(false)
  transactions   Transaction[]
  avatar         String?
  examGrades     ExamGrade[]       @relation("StudentExamGrades")
  bonuses        StudentBonus[]

  @@index([status])
  @@index([fio])
  @@map("students")
}

model Course {
  id       Int       @id @default(autoincrement())
  name     String
  price    Int
  branchId Int
  branch   Branch    @relation(fields: [branchId], references: [id])
  students Student[]
  mentors  Mentor[]
  groups   Group[]
  leeds    Leed[]

  @@map("courses")
}

model Group {
  id            Int            @id @default(autoincrement())
  name          String
  status        GroupStatus    @default(waiting)
  courseId      Int
  course        Course         @relation(fields: [courseId], references: [id])
  classDays     ClassDays[]
  startTime     String
  endTime       String
  fromDate      DateTime
  toDate        DateTime
  mentorId      Int?
  mentor        Mentor?        @relation("MentorGroup", fields: [mentorId], references: [id])
  responsible   User?          @relation("ResponsibleGroups", fields: [responsibleId], references: [id])
  responsibleId Int?
  lesson        Lesson[]
  groupStudents GroupStudent[]
  exams         Exam[]         @relation("GroupExams")

  @@map("groups")
}

model GroupStudent {
  groupId         Int
  studentId       Int
  discount        Float?             @default(0)
  discountComment String?
  status          GroupStudentStatus @default(active)
  group           Group              @relation(fields: [groupId], references: [id])
  student         Student            @relation(fields: [studentId], references: [id])

  @@id([groupId, studentId])
  @@index([studentId, status])
  @@map("group_students")
}

model Lesson {
  id            Int               @id @default(autoincrement())
  name          String
  date          DateTime
  status        LessonStatus?     @default(waiting)
  comment       String?
  startTime     String
  endTime       String
  groupId       Int?
  group         Group?            @relation(fields: [groupId], references: [id])
  students      StudentOnLesson[]
  mentorId      Int?
  mentor        Mentor?           @relation(fields: [mentorId], references: [id])
  responsibleId Int?
  responsible   User?             @relation("ResponsibleForLessons", fields: [responsibleId], references: [id])
  branchId      Int?
  branch        Branch?           @relation(fields: [branchId], references: [id])

  @@index([date, groupId])
  @@index([groupId, status])
  @@index([date, status])
  @@map("lessons")
}

model StudentOnLesson {
  studentId Int
  lessonId  Int
  attended  Boolean
  discount  Int?
  reason    LessonStudentReason?

  student Student? @relation(fields: [studentId], references: [id])
  lesson  Lesson?  @relation(fields: [lessonId], references: [id])

  @@id([studentId, lessonId])
  @@map("student_on_lesson")
}

model StudentBonus {
  id            Int      @id @default(autoincrement())
  name          String
  date          DateTime
  amount        Float
  comment       String
  studentId     Int
  student       Student  @relation(fields: [studentId], references: [id])
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id])
  mentorPercent Int?

  @@map("student_bonuses")
}

model Transaction {
  id          Int             @id @default(autoincrement())
  type        TransactionType
  date        DateTime
  amount      Float
  authorId    Int?
  author      User?           @relation("AuthorTransactions", fields: [authorId], references: [id])
  comment     String?
  paymentType PaymentType?
  studentId   Int?
  student     Student?        @relation(fields: [studentId], references: [id])
  userId      Int?
  user        User?           @relation("UserTransactions", fields: [userId], references: [id])
  expenseType ExpenseType?
  profitType  ProfitType?
  branchId    Int
  branch      Branch          @relation(fields: [branchId], references: [id])

  @@index([date, branchId])
  @@index([type, date])
  @@index([studentId, date])
  @@map("transactions")
}

model Fine {
  id       Int      @id @default(autoincrement())
  name     String
  date     DateTime
  amount   Float
  comment  String
  userId   Int
  user     User     @relation("FinesReceived", fields: [userId], references: [id])
  authorId Int
  author   User     @relation("FinesAuthored", fields: [authorId], references: [id])
  branchId Int
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@map("fines")
}

model Bonus {
  id       Int      @id @default(autoincrement())
  name     String
  date     DateTime
  amount   Float
  comment  String
  userId   Int
  user     User     @relation("BonusesReceived", fields: [userId], references: [id])
  authorId Int
  author   User     @relation("BonusesAuthored", fields: [authorId], references: [id])
  branchId Int
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@map("bonuses")
}

model Exam {
  id            Int         @id @default(autoincrement())
  name          String
  groupId       Int
  group         Group       @relation(fields: [groupId], references: [id], name: "GroupExams")
  status        ExamStatus  @default(new)
  responsibleId Int
  responsible   User        @relation(fields: [responsibleId], references: [id], name: "ResponsibleExams")
  comments      String?
  date          DateTime
  grades        ExamGrade[] @relation("grades")

  @@map("exams")
}

model ExamGrade {
  id        Int     @id @default(autoincrement())
  examId    Int
  studentId Int
  grade     Float?
  comment   String?
  exam      Exam    @relation(fields: [examId], references: [id], name: "grades")
  student   Student @relation(fields: [studentId], references: [id], name: "StudentExamGrades")

  @@unique([examId, studentId])
  @@map("exam_grades")
}

enum ExamStatus {
  new
  passed
  cancelled
}

enum MentorStatus {
  active
  noActive
}

enum TransactionType {
  in
  out
}

enum ExpenseType {
  salary
  rent
  communal
  other
}

enum ProfitType {
  payment
  other
}

enum PaymentType {
  cash
  click
  card
  transfer
}

enum LessonStatus {
  waiting
  waitingConfirm
  completed
  cancelled
  notPassed
}

enum LessonStudentReason {
  gotSick
  askedOff
  unknown
}

enum StudentStatus {
  active
  noActive
  vacation
}

enum LeedStatus {
  new
  refused
  waitingGroup
  inGroup
  finished
}

enum DiscoveryMethod {
  streetAd
  fromFriends
  radio
  tv
  telegram
  instagram
}

enum GroupStatus {
  waiting
  active
  frozen
  completed
}

enum GroupStudentStatus {
  active
  stopped
  completed
}

enum ClassDays {
  even
  odd
  every
  Mon
  Tues
  Wednes
  Thurs
  Fri
  Satur
  Sun
}

enum Role {
  CEO
  admin
  manager
  mentor
  assistent
}

enum MentorSalaryType {
  fixed
  fixedLesson
  percentLesson
}

enum UserStatusType {
  work
  noWork
  onSickLeave
  onVacation
}

// ============================================================
// Wave 1 — infra tables: Notifications, Audit log, Refresh token
// All fields nullable where it makes sense to keep initial
// migration additive and reversible.
// ============================================================

enum NotificationChannel {
  sms
  telegram
  email
  push
}

enum NotificationStatus {
  queued
  sent
  delivered
  failed
  skipped
}

model NotificationTemplate {
  id        Int                 @id @default(autoincrement())
  code      String
  channel   NotificationChannel
  locale    String              @default("ru")
  subject   String?
  body      String
  // Optional JSON list of variable names rendered into `body` (informational).
  variables Json?
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  logs NotificationLog[]

  @@unique([code, channel, locale])
  @@index([channel, enabled])
  @@map("notification_templates")
}

model NotificationLog {
  id          Int                   @id @default(autoincrement())
  templateId  Int?
  template    NotificationTemplate? @relation(fields: [templateId], references: [id])
  channel     NotificationChannel
  recipient   String
  status      NotificationStatus    @default(queued)
  payload     Json?
  error       String?
  // BullMQ job id so we can cross-reference in queue dashboards.
  jobId       String?
  sentAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime              @default(now())

  @@index([recipient, createdAt])
  @@index([channel, status, createdAt])
  @@map("notification_logs")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  // Actor — nullable because some actions run from system (cron, webhook).
  userId    Int?
  action    String // e.g. "student.update", "transaction.create"
  entity    String // e.g. "Student", "Transaction"
  entityId  String? // stringified id, to support composite keys later
  // Snapshot of changed fields / before-after. Shape up to caller.
  diff      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int
  // SHA-256 of the raw token. We never store the token itself.
  tokenHash  String    @unique
  deviceId   String?
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================================
// Wave 1 — hot-path indexes on existing tables (additive only).
// Declared on the respective models below.
// ============================================================

// ============================================================
// Wave 2 — feature tables
// ============================================================

enum TaskStatus {
  pending
  inProgress
  done
  cancelled
}

model Task {
  id            Int        @id @default(autoincrement())
  title         String
  description   String?
  dueAt         DateTime?
  /// Кому назначено.
  assignedTo    Int?
  /// Свободный тип сущности: "student" | "leed" | "group" — чтобы не
  /// плодить полиморфные FK. Поиск ведём по (relatedEntity, relatedId).
  relatedEntity String?
  relatedId     Int?
  status        TaskStatus @default(pending)
  createdBy     Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([assignedTo, status])
  @@index([dueAt, status])
  @@index([relatedEntity, relatedId])
  @@map("tasks")
}

enum PaymentPlanStatus {
  active
  completed
  cancelled
}

enum PaymentPlanItemStatus {
  pending
  paid
  overdue
  cancelled
}

model PaymentPlan {
  id          Int               @id @default(autoincrement())
  studentId   Int
  totalAmount Float
  monthsCount Int
  startDate   DateTime
  status      PaymentPlanStatus @default(active)
  comment     String?
  createdBy   Int?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  items PaymentPlanItem[]

  @@index([studentId, status])
  @@map("payment_plans")
}

model PaymentPlanItem {
  id                Int                   @id @default(autoincrement())
  planId            Int
  plan              PaymentPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  dueDate           DateTime
  amount            Float
  paidAmount        Float                 @default(0)
  status            PaymentPlanItemStatus @default(pending)
  /// Какая транзакция закрыла платёж (опционально, для истории).
  paidTransactionId Int?
  createdAt         DateTime              @default(now())

  @@index([planId, dueDate])
  @@index([status, dueDate])
  @@map("payment_plan_items")
}

enum HomeworkSubmissionStatus {
  submitted
  reviewed
  returned
}

model Homework {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  /// Либо groupId (для всей группы), либо lessonId (урок-specific).
  groupId     Int?
  lessonId    Int?
  dueDate     DateTime?
  /// JSON список ссылок на файлы (пока локальные uploads/, потом S3).
  attachments Json?
  createdBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  submissions HomeworkSubmission[]

  @@index([groupId, dueDate])
  @@index([lessonId])
  @@map("homeworks")
}

model HomeworkSubmission {
  id              Int                      @id @default(autoincrement())
  homeworkId      Int
  homework        Homework                 @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  studentId       Int
  /// Текст ответа или комментарий студента.
  comment         String?
  /// JSON список файлов студента.
  files           Json?
  grade           Float?
  reviewerComment String?
  status          HomeworkSubmissionStatus @default(submitted)
  submittedAt     DateTime                 @default(now())
  reviewedAt      DateTime?
  reviewedBy      Int?

  @@unique([homeworkId, studentId])
  @@index([studentId])
  @@map("homework_submissions")
}

model TelegramLink {
  id             Int       @id @default(autoincrement())
  /// Привязка либо к User (сотрудник), либо к Student/родителю.
  userId         Int?
  studentId      Int?
  /// Идентификатор в Telegram (chat_id / from.id). Уникален.
  telegramUserId String    @unique
  username       String?
  /// Однократный код при установке через команду /start.
  linkCode       String?   @unique
  active         Boolean   @default(true)
  linkedAt       DateTime  @default(now())
  lastSeenAt     DateTime?

  @@index([userId])
  @@index([studentId])
  @@map("telegram_links")
}
