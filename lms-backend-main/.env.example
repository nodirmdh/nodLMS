# === Required ===
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct connection (no pgbouncer). Required for Prisma Migrate on Neon/Supabase.
# Same as DATABASE_URL but without the pooler host. Optional in other setups.
DIRECT_URL=""
ACCESS_TOKEN_SECRET="replace-with-16+-char-random-string"

# === Server ===
PORT=3002
NODE_ENV=production

# === CORS (comma-separated list) ===
CORS_ORIGIN="https://your-frontend.vercel.app,http://localhost:3001"

# === SMS gateway ===
SMS_USERNAME=""
SMS_SECRET_KEY=""

# === Dev / testing ===
# Set to 'true' to bypass OTP check (uses 000000 as the code). Never in real prod.
DEV_OTP_BYPASS=false

# === Swagger protection (production) ===
# If both are set, /docs requires Basic Auth in production.
# If either is empty in production -> /docs is disabled.
SWAGGER_USER=""
SWAGGER_PASSWORD=""

# === Telegram (future) ===
TELEGRAM_BOT_TOKEN="8525635658:AAHRKGhnL8ZcjyqvoHPNn_WAoBkt2lu1myE"
TELEGRAM_WEBHOOK_SECRET="r86BH8hTPL3s4ck"

# === Redis / BullMQ ===
# Either REDIS_URL OR (REDIS_HOST + REDIS_PORT). URL wins if both provided.
# For TLS use `rediss://...` or set REDIS_TLS=true.
REDIS_URL=""
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0
REDIS_TLS=false
# Optional prefix applied to the shared ioredis client (NOT to BullMQ keys).
REDIS_KEY_PREFIX=""
# BullMQ key namespace. Default "bull". Override per environment to keep
# dev/staging/prod queues isolated inside a shared Redis instance.
BULL_PREFIX="bull"

# === Auth ===
# TTL для refresh-token в днях (default 30)
REFRESH_TOKEN_TTL_DAYS=30

# === Feature flags ===
# true → финансовые SMS идут через NotificationService (очередь + шаблоны).
# false (default) → старый sync-путь через SMSService.
NOTIFY_VIA_QUEUE=false

# true → TasksService cron'ы заменяются на BullMQ repeat-jobs.
# false (default) → @nestjs/schedule в API-процессе.
SCHEDULER_VIA_QUEUE=false

# true — API-процесс сам крутит @Processor'ы (dev, single-box).
# false — API только продюсер, воркеры живут в отдельном `start:worker` процессе.
WORKERS_IN_API=true

# === Sentry (optional) ===
# DSN от вашего Sentry-проекта. Пусто = Sentry выключен.
SENTRY_DSN=""
SENTRY_ENVIRONMENT=""
SENTRY_RELEASE=""
# Performance sampling (0..1). Default 0 = только ошибки, без tracing.
SENTRY_TRACES_RATE=0
